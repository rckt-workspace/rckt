# Supabase (server) — proyecto en supabase.com, no en Lovable Cloud una vez migrado
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_PROJECT_ID=
# Service role key: NO está en Lovable Cloud por defecto — Lovable la inyecta de forma
# invisible en su propio hosting. Fuera de Lovable (Render, local) hay que copiarla
# manualmente desde Supabase Dashboard > Project Settings > API > service_role.
# Requerida por /api/leads y /api/save-chat-lead (client.server.ts). Sin ella, ambos
# endpoints responden 500 "Missing Supabase environment variable(s)".
SUPABASE_SERVICE_ROLE_KEY=

# Supabase (cliente, se inyectan en build vía Vite)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# AI Gateway de Lovable (ai.gateway.lovable.dev) — requerido por /api/advisor-chat.
# Es un servicio propietario de Lovable con créditos propios; sigue siendo una
# dependencia externa aunque el hosting se mueva a Render.
LOVABLE_API_KEY=
